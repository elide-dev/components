{
  "name": "@elide/tokens",
  "version": "0.1.0",
  "description": "Framework-agnostic design tokens for Elide — CSS custom properties, a Tailwind v4 theme, and a typed JS/TS object. No framework dependency; safe to consume from any repo.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./theme.css": "./src/theme.css",
    "./fonts.css": "./src/fonts.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  }
}
